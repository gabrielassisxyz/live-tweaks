#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."
echo "==> install";     npm ci
echo "==> lint+format"; npx biome ci .
echo "==> typecheck";   npx tsc --noEmit
echo "==> test";        npm test
echo "==> build";       npm run build
echo "==> audit";       npm audit --audit-level=high
# anti-slop gate: em-dash in prose + the tool-name leak. Canonical: llm-workflow bin/slop-guard.
echo "==> slop-guard"; bin/slop-guard --diff "${SLOP_GUARD_BASE:-origin/master}"

echo "CI green."
